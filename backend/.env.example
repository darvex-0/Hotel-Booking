# APPLICATION VARIABLES
APP_NAME = "Beach Resort"
APP_PORT = 5000
APP_NODE_ENV = development
APP_BASE_URL = http://localhost:5000
APP_SERVICE_URL = http://localhost:5000
APP_LOG_LEVEL = info

# DATABASE VARIABLES (MySQL)
DB_HOST = localhost
DB_USER = root
DB_PASSWORD = 
DB_NAME = hotel_booking_system

# JWT VARIABLES
JWT_SECRET_KEY = your_super_secret_key
JWT_REFRESH_TOKEN_SECRET_KEY = your_super_secret_refresh_key
JWT_ACCESS_TOKEN_EXPIRES = 1d
JWT_REFRESH_TOKEN_EXPIRES = 7d
JWT_TOKEN_COOKIE_EXPIRES = 1

# EMAIL VARIABLES (Brevo/SMTP)
SEND_SENDER_MAIL = your_email@example.com
EMAIL_HOST = smtp-relay.brevo.com
EMAIL_PORT = 587
EMAIL_USER = your_smtp_user
EMAIL_PASS = your_smtp_password
